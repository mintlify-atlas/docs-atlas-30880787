  "publicApiSurface": [
    "GET /api/mail/threads — list email threads by folder",
    "GET /api/mail/thread/:id — get a single thread",
    "POST /api/mail/send — send a new email",
    "POST /api/mail/draft — create a draft",
    "DELETE /api/mail/thread/:id — delete a thread",
    "PATCH /api/mail/labels — modify thread labels",
    "GET /api/labels — list user labels",
    "POST /api/labels — create a label",
    "DELETE /api/labels/:id — delete a label",
    "POST /api/ai/compose — AI-assisted email composition",
    "POST /api/ai/search — semantic search over mailbox",
    "GET /api/connections — list connected email accounts",
    "MailManager interface — get, create, list, delete, markAsRead, markAsUnread, modifyLabels, getUserLabels, createLabel, deleteLabel, getEmailAliases",
    "nizzy CLI — env setup, sync environment variables"
  ]
